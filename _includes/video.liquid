{% comment %}
  Use src on <video> (not nested <source>) so HTML minifiers don't emit invalid </source>.
  Jekyll passes include flags as strings: autoplay=false becomes the string "false", which is truthy in Liquid — only enable autoplay for boolean true or string "true".
  preload: none | metadata (default) | auto — auto can help flaky local servers; none reduces work when many players are on one page.
  portrait_wrap: stable 9:16 box for tall phone clips (avoids layout jump / “twitch” on play).
  novolume: controlslist="novolume" (Chromium) + muted; use for silent B-roll.
{% endcomment %}
{% assign extension = include.path | split: '.' | last %}
{% assign video_src = include.path | relative_url %}
{% if include.cache_bust %}
  {% assign video_src = include.path | relative_url | bust_file_cache %}
{% endif %}

{% assign enable_autoplay = false %}
{% if include.autoplay == true or include.autoplay == 'true' %}
  {% assign enable_autoplay = true %}
{% endif %}

{% assign enable_controls = true %}
{% if include.controls == false or include.controls == 'false' %}
  {% assign enable_controls = false %}
{% endif %}

{% assign enable_muted = false %}
{% if include.muted == true or include.muted == 'true' %}
  {% assign enable_muted = true %}
{% endif %}
{% if enable_autoplay %}
  {% assign enable_muted = true %}
{% endif %}

{% assign enable_novolume = false %}
{% if include.novolume == true or include.novolume == 'true' %}
  {% assign enable_novolume = true %}
  {% assign enable_muted = true %}
{% endif %}

{% assign v_preload = 'metadata' %}
{% if include.preload == 'none' or include.preload == 'auto' %}
  {% assign v_preload = include.preload %}
{% endif %}

{% assign use_portrait_wrap = false %}
{% if include.portrait_wrap == true or include.portrait_wrap == 'true' %}
  {% assign use_portrait_wrap = true %}
{% endif %}

{% assign clist = '' %}
{% if enable_novolume %}
  {% assign clist = 'novolume' %}
{% endif %}

<figure>
  {% if extension == 'mp4' or extension == 'MP4' or extension == 'webm' or extension == 'ogg' %}
    {% if use_portrait_wrap %}
      <div class="ratio portfolio-video-portrait mx-auto">
    {% endif %}
    <video
      src="{{ video_src }}"
      {% if use_portrait_wrap %}
        class="{% if include.class %}{{ include.class }} {% endif %}object-fit-contain position-absolute top-0 start-0 w-100 h-100"
      {% elsif include.class %}
        class="{{ include.class }}"
      {% endif %}
      {% unless use_portrait_wrap %}
        {% if include.width %}
          width="{{ include.width }}"
        {% else %}
          width="100%"
        {% endif %}
        {% if include.height %}
          height="{{ include.height }}"
        {% else %}
          height="auto"
        {% endif %}
      {% endunless %}
      {% if include['min-width'] %}
        min-width="{{ include.min-width }}"
      {% endif %}
      {% if include['min-height'] %}
        min-height="{{ include.min-height }}"
      {% endif %}
      {% if include['max-width'] %}
        max-width="{{ include.max-width }}"
      {% endif %}
      {% if include['max-height'] %}
        max-height="{{ include.max-height }}"
      {% endif %}
      {% if include.title %}
        title="{{ include.title }}"
      {% endif %}
      {% if enable_autoplay %}
        autoplay
      {% endif %}
      {% if enable_controls %}
        controls
      {% endif %}
      {% if include.loop == true or include.loop == 'true' %}
        loop
      {% endif %}
      {% if enable_muted %}
        muted
      {% endif %}
      playsinline
      preload="{{ v_preload }}"
      {% if clist != '' %}
        controlslist="{{ clist }}"
      {% endif %}
      {% if include.poster %}
        poster="{{ include.poster | relative_url }}"
      {% endif %}
    >
      <p class="text-muted small mb-0">Your browser cannot play this video inline. <a href="{{ video_src }}" download>Download the file</a>.</p>
    </video>
    {% if use_portrait_wrap %}
      </div>
    {% endif %}
  {% else %}
    <iframe
      src="{{ include.path }}"
      {% if include.class %}
        class="{{ include.class }}"
      {% endif %}
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      {% if include.width %}
        width="{{ include.width }}"
      {% else %}
        width="auto"
      {% endif %}
      {% if include.height %}
        height="{{ include.height }}"
      {% else %}
        height="auto"
      {% endif %}
      {% if include['min-width'] %}
        min-width="{{ include.min-width }}"
      {% endif %}
      {% if include['min-height'] %}
        min-height="{{ include.min-height }}"
      {% endif %}
      {% if include['max-width'] %}
        max-width="{{ include.max-width }}"
      {% endif %}
      {% if include['max-height'] %}
        height="{{ include.max-height }}"
      {% endif %}
      {% if include.alt %}
        alt="{{ include.alt }}"
      {% endif %}
      {% if include.title %}
        title="{{ include.title }}"
      {% endif %}
    ></iframe>
  {% endif %}
  {% if include.caption %}
    <figcaption class="caption">{{ include.caption }}</figcaption>
  {% endif %}
</figure>
